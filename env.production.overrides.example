# Production overrides — values that differ from local .env
# Copy this file to .env.production.overrides and fill in prod values
#
# Usage:
#   cp env.production.overrides.example .env.production.overrides
#   # Edit with your production values
#   npm run env:push

# Production bot token (different from dev bot)
TELEGRAM_BOT_TOKEN=your_production_bot_token_here

# Production webapp URL
WEBAPP_URL=https://89-167-19-222.sslip.io

# Environment
NODE_ENV=production
