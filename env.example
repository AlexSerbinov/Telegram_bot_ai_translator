# Telegram Bot Configuration
# DEV bot token for local development, PROD token on server
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI Configuration (required by validator, but actual translation uses Gemini)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs Configuration (STT + TTS)
ELEVEN_LABS_API_KEY=your_elevenlabs_api_key_here
ELEVEN_LABS_TTS_VOICE=FFHOCNsj5TuX6tRgEswC

# Translation provider: 'gemini' (default) | 'groq'
TRANSLATION_PROVIDER=gemini

# Google Gemini Configuration (translation + language detection)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Groq Configuration (fast LPU inference, OpenAI-compatible)
GROQ_API_KEY=your_groq_api_key_here
# TRANSLATION_MODEL=openai/gpt-oss-120b

# Soniox Configuration (real-time STT in Mini App)
SONIOX_API_KEY=your_soniox_api_key_here
STT_PROVIDER=soniox

# Bot Configuration
NODE_ENV=development
LOG_LEVEL=info

# Audio Configuration
MAX_AUDIO_SIZE=50MB
TEMP_AUDIO_DIR=./temp/audio

# MongoDB Configuration
MONGODB_URI=mongodb://admin:secretpassword@localhost:27017/ai-translator?authSource=admin

# Server Configuration (Mini App)
# Local dev: http://localhost:3001 (scripts/dev.sh updates this to ngrok URL)
# Production: https://89-167-19-222.sslip.io
SERVER_PORT=3001
WEBAPP_URL=http://localhost:3001

# Token Limits Configuration
FREE_TIER_DAILY_TOKENS=10000
FREE_TIER_MONTHLY_TOKENS=100000
