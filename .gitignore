# Xcode — build artefacts (NEVER commit)
# `build/` was the only dir captured before, but xcodebuild can output to
# `build-sim/`, `build-device/`, `build-XYZ/` depending on -derivedDataPath
# flags and CI matrix. Glob covers all of them.
build/
build-*/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.moved-aside

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.resolved
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/

# Generated by xcodegen
TeycanTranslate.xcodeproj/

# macOS
.DS_Store

# Misc
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
